<Window x:Class="SmartSleepShutdown.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:SmartSleepShutdown.App.ViewModels"
        Title="Smart Sleep Shutdown"
        Width="520"
        Height="560"
        MinWidth="500"
        MinHeight="540"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#EEF3F8">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderBrush" Value="#CAD5E2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderBrush" Value="#B9C7D6" />
            <Setter Property="Background" Value="#FFFFFF" />
        </Style>

        <Style TargetType="ToggleButton">
            <Setter Property="Height" Value="48" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="Background" Value="#E6EDF5" />
            <Setter Property="BorderBrush" Value="#B9C7D6" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#102033"
                Padding="22,20">
            <DockPanel LastChildFill="True">
                <Border Width="52"
                        Height="52"
                        CornerRadius="12"
                        Background="#F8FAFC"
                        DockPanel.Dock="Left"
                        Margin="0,0,14,0">
                    <Grid>
                        <TextBlock Text="SS"
                                   Foreground="#102033"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        <Ellipse Width="12"
                                 Height="12"
                                 Fill="#16A34A"
                                 Stroke="#FFFFFF"
                                 StrokeThickness="2"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Bottom"
                                 Margin="0,0,6,6" />
                    </Grid>
                </Border>

                <StackPanel>
                    <TextBlock Text="Smart Sleep Shutdown"
                               Foreground="#F8FAFC"
                               FontSize="23"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Guardian nocturno para apagar solo cuando es seguro"
                               Foreground="#B8C6D6"
                               FontSize="13"
                               Margin="0,3,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <StackPanel Grid.Row="1"
                    Margin="22,20,22,12">
            <Border Background="#FFFFFF"
                    BorderBrush="#D9E2EC"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="Estado"
                               Foreground="#64748B"
                               FontSize="12"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding StatusText}"
                               Margin="0,3,0,0"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#0F172A"
                               AutomationProperties.LiveSetting="Polite" />
                    <TextBlock Text="No apaga sin aviso. Mueve el raton o pulsa una tecla para cancelar."
                               Margin="0,6,0,0"
                               Foreground="#475569"
                               FontSize="12"
                               TextWrapping="Wrap" />
                    <Border Margin="0,10,0,0"
                            Padding="10,8"
                            CornerRadius="6"
                            Background="#FEF2F2"
                            BorderBrush="#FCA5A5"
                            BorderThickness="1"
                            Visibility="{Binding IsSettingsWarningVisible, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding SettingsWarningText}"
                                   Foreground="#991B1B"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </Border>

            <ToggleButton Margin="0,14,0,14"
                          IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                          Content="{Binding IsEnabled, Converter={x:Static viewModels:BooleanBoxes.OnOffConverter}}"
                          AutomationProperties.Name="Activar o desactivar apagado inteligente" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Hora de inicio"
                               FontWeight="SemiBold"
                               Foreground="#0F172A" />
                    <TextBox Margin="0,6,0,0"
                             Text="{Binding StartTimeText, UpdateSourceTrigger=LostFocus}"
                             AutomationProperties.Name="Hora de inicio" />
                    <TextBlock Text="Formato 24h, por ejemplo 01:00"
                               Margin="0,5,0,0"
                               Foreground="#64748B"
                               FontSize="12" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Inactividad"
                               FontWeight="SemiBold"
                               Foreground="#0F172A" />
                    <TextBox Margin="0,6,0,0"
                             Text="{Binding IdleThresholdMinutes, UpdateSourceTrigger=LostFocus}"
                             AutomationProperties.Name="Minutos de inactividad" />
                    <TextBlock Text="Minutos antes de avisar"
                               Margin="0,5,0,0"
                               Foreground="#64748B"
                               FontSize="12" />
                </StackPanel>
            </Grid>

            <Border Margin="0,16,0,0"
                    Background="#FFFFFF"
                    BorderBrush="#D9E2EC"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">
                <DockPanel LastChildFill="True">
                    <CheckBox DockPanel.Dock="Left"
                              Margin="0,2,12,0"
                              IsChecked="{Binding ContextChecksEnabled, Mode=TwoWay}"
                              AutomationProperties.Name="Activar comprobaciones de contexto" />
                    <StackPanel>
                        <TextBlock Text="Comprobaciones de contexto"
                                   FontWeight="SemiBold"
                                   Foreground="#0F172A" />
                        <TextBlock Text="Bloquea el apagado si hay audio, pantalla completa, CPU alta o apps importantes."
                                   Margin="0,4,0,0"
                                   Foreground="#64748B"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#ECFDF5"
                        BorderBrush="#BBF7D0"
                        BorderThickness="1"
                        CornerRadius="7"
                        Padding="10">
                    <TextBlock Text="1. Avisa 60 segundos"
                               Foreground="#14532D"
                               FontSize="12"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                </Border>

                <Border Grid.Column="2"
                        Background="#EFF6FF"
                        BorderBrush="#BFDBFE"
                        BorderThickness="1"
                        CornerRadius="7"
                        Padding="10">
                    <TextBlock Text="2. Cancela con actividad"
                               Foreground="#1E3A8A"
                               FontSize="12"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                </Border>

                <Border Grid.Column="4"
                        Background="#F8FAFC"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        CornerRadius="7"
                        Padding="10">
                    <TextBlock Text="3. Revisa bloqueos"
                               Foreground="#334155"
                               FontSize="12"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                </Border>
            </Grid>
        </StackPanel>

        <Border Grid.Row="2"
                Margin="22,0,22,12"
                Padding="14"
                CornerRadius="8"
                Background="#FFF7ED"
                BorderBrush="#FDBA74"
                BorderThickness="1"
                Visibility="{Binding IsCountdownActive, Converter={StaticResource BoolToVisibility}}">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        Width="96"
                        Margin="12,0,0,0"
                        Content="Cancelar"
                        Command="{Binding CancelShutdownCommand}"
                        AutomationProperties.Name="Cancelar apagado" />
                <TextBlock VerticalAlignment="Center"
                           Foreground="#7C2D12"
                           FontWeight="SemiBold">
                    <Run Text="Apagado en " />
                    <Run Text="{Binding CountdownSecondsRemaining, Mode=OneWay}" />
                    <Run Text=" segundos" />
                </TextBlock>
            </DockPanel>
        </Border>

        <Border Grid.Row="3"
                Background="#E8EEF5"
                BorderBrush="#D6E0EA"
                BorderThickness="1,1,0,0"
                Padding="18,12">
            <DockPanel LastChildFill="False">
                <TextBlock Text="Al cerrar, sigue activo junto al reloj. Icono verde activo. Click izquierdo en el icono para abrir."
                           Foreground="#475569"
                           FontSize="12"
                           TextWrapping="Wrap"
                           DockPanel.Dock="Left" />
                <Button Content="Pausar hoy"
                        Margin="16,0,0,0"
                        Command="{Binding DisableUntilTomorrowCommand}"
                        AutomationProperties.Name="Pausar hasta manana"
                        DockPanel.Dock="Right" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
