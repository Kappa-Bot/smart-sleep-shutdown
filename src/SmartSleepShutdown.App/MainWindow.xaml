<Window x:Class="SmartSleepShutdown.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:SmartSleepShutdown.App.ViewModels"
        Title="Smart Sleep Shutdown"
        Width="440"
        Height="320"
        MinWidth="420"
        MinHeight="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <DockPanel>
                <Border Width="40"
                        Height="40"
                        CornerRadius="10"
                        Background="#122033"
                        DockPanel.Dock="Left"
                        Margin="0,0,12,0">
                    <TextBlock Text="SS"
                               Foreground="#F8FAFC"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <StackPanel>
                    <TextBlock Text="SMART SLEEP SHUTDOWN"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#0F172A" />
                    <TextBlock Text="Silent night guard"
                               FontSize="12"
                               Foreground="#64748B" />
                </StackPanel>
            </DockPanel>
            <TextBlock Text="{Binding StatusText}"
                       Margin="0,8,0,0"
                       FontSize="20"
                       FontWeight="SemiBold"
                       AutomationProperties.LiveSetting="Polite"
                       Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />
        </StackPanel>

        <ToggleButton Grid.Row="1"
                      Margin="0,22,0,18"
                      Height="44"
                      IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                      Content="{Binding IsEnabled, Converter={x:Static viewModels:BooleanBoxes.OnOffConverter}}"
                      AutomationProperties.Name="Enable smart shutdown" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="36" />
                <RowDefinition Height="36" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Start time" />
            <TextBox Grid.Row="0"
                     Grid.Column="1"
                     Height="28"
                     Text="{Binding StartTimeText, UpdateSourceTrigger=PropertyChanged}"
                     AutomationProperties.Name="Start time" />

            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Idle minutes" />
            <TextBox Grid.Row="1"
                     Grid.Column="1"
                     Height="28"
                     Text="{Binding IdleThresholdMinutes, UpdateSourceTrigger=PropertyChanged}"
                     AutomationProperties.Name="Idle threshold minutes" />

            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Context checks" />
            <CheckBox Grid.Row="2"
                      Grid.Column="1"
                      VerticalAlignment="Center"
                      IsChecked="{Binding ContextChecksEnabled, Mode=TwoWay}"
                      AutomationProperties.Name="Enable context checks" />
        </Grid>

        <Border Grid.Row="3"
                Padding="10"
                Background="{DynamicResource {x:Static SystemColors.InfoBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="1"
                Visibility="{Binding IsCountdownActive, Converter={StaticResource BoolToVisibility}}">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        Width="80"
                        Margin="10,0,0,0"
                        Content="Cancel"
                        Command="{Binding CancelShutdownCommand}"
                        AutomationProperties.Name="Cancel shutdown" />
                <TextBlock VerticalAlignment="Center">
                    <Run Text="Shutdown in " />
                    <Run Text="{Binding CountdownSecondsRemaining, Mode=OneWay}" />
                    <Run Text=" seconds" />
                </TextBlock>
            </DockPanel>
        </Border>
    </Grid>
</Window>
